```gitignore
# Dependencies
node_modules/

# Build artifacts
dist/
build/
*.min.js
*.min.css
*.bundle.js

# Environment
.env
.env.local
*.env.*

# Logs
*.log

# Coverage
coverage/
htmlcov/
*.coverage

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg-info/
.eggs/

# Node
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Testing
.mypy_cache/
.pytest_cache/
.nyc_output/

# Distribution
*.tar.gz
*.zip
*.tar
*.gz

# Compiled
*.exe
*.dll
*.so
*.a
*.obj
*.out
```