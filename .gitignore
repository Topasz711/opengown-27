```gitignore
# Dependencies
node_modules/

# Build artifacts
dist/
build/
target/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
.ENV
.python-version

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables
.env
.env.local
.env.*
!.env.example

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Coverage reports
coverage/
htmlcov/
.coverage

# Testing
.pytest_cache/
.mypy_cache/
*.pytest_cache/

# Compressed files
*.zip
*.tar.gz
*.tar.bz2
*.tar.xz
*.gz
*.rar
*.7z
```