```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
*.js.map

# Environment
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log

# Coverage
coverage/
htmlcov/
.coverage

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg-info/
.eggs/

# Temp files
*.tmp
*~
.DS_Store
Thumbs.db

# MyPy
.mypy_cache/
.dmypy.json
dmypy.json

# Pytest
.pytest_cache/

# Distribution / packaging
.Python
*.so
.Python
*.pyc
*.pyo
*.pyd
*.egg-info/
.eggs/
.venv/
venv/
ENV/

# IDEs
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Thumbs.db:encryptable
*:encryptable
*.swp
*.swo

# Local configuration files
.env.local
.env.*.local

# Coverage directory used by tools like istanbul
coverage/

# nyc test coverage
.nyc_output

# Grunt intermediate storage (https://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-waf configuration
.lock-wscript

# Compiled binary files
*.exe
*.dll
*.so
*.dylib

# Various IDEs
.project
*.tmproj
*.sublime-project
*.sublime-workspace
nbproject/
*.xcodeproj/
xcuserdata/
*.xcworkspace/
playground/
.vs/
```