```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
*.js.map

# Logs and temporary files
*.log
*.tmp

# Environment variables
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so

# Coverage reports
coverage/
htmlcov/
.coverage

# Testing
.pytest_cache/
.mypy_cache/
.tox/

# Distribution / packaging
.pytest_cache/
.coverage
htmlcov/
.cov/
coverage.xml

# Local configuration
.env*
!.env.example

# OS generated files
.DS_Store
Thumbs.db
```