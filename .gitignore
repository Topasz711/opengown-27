```gitignore
# Dependencies
node_modules/

# Build artifacts
frontend/node_modules/

# Vite specific
frontend/node_modules/.vite/

# Environment variables
.env
.env.local
.env.*

# Logs
*.log

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Temp files
*.tmp
*.swp

# Python cache (if any Python files were detected in the project)
__pycache__/
*.pyc
*.pyo
*.pyd

# Distribution / Build folders (common names)
dist/
build/
target/
out/
coverage/
htmlcov/
.mypy_cache/
.pytest_cache/
.gradle/
```